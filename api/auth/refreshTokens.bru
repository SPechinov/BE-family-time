meta {
  name: refreshTokens
  type: http
  seq: 9
}

post {
  url: {{url}}/auth/refresh-tokens
  body: formUrlEncoded
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

script:post-response {
  bru.setVar("authToken", res.headers.authorization)
  
}

settings {
  encodeUrl: true
  timeout: 0
}
